# Dependency directories
# These are installed by package managers and should not be in version control.
node_modules/

# Build output
# This is the compiled JavaScript from your TypeScript source.
dist/
build/

# Environment variables
# Never commit secrets or environment-specific configurations.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
# Log files are generated during execution and can become large.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDEs and editor-specific files
.vscode/
.idea/

# OS-generated files
.DS_Store
Thumbs.db

# Test and coverage reports
coverage/
.nyc_output/